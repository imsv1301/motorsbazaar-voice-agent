# Copy this file to .env and fill in your values

# ── AI (Required) ─────────────────────────────────────────────────────────────
# Get your free Groq API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Google Sheets (Required) ──────────────────────────────────────────────────
# LOCAL DEV: path to your downloaded service-account JSON file
GOOGLE_CREDENTIALS_PATH=credentials/service-account.json

# RENDER / CLOUD: paste the entire contents of service-account.json as one line
# (leave blank for local dev, set this on Render instead of the file)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Exact name of your Google Sheet
GOOGLE_SHEET_NAME=MotorsBazaar Consultations

# ── CORS (Required) ───────────────────────────────────────────────────────────
# Frontend URL - comma separated (add your Vercel URL when deployed)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Twilio Phone Calls (Optional) ────────────────────────────────────────────
# Sign up free at https://twilio.com — get $15 free credit + a phone number
# Leave blank if you only want the web voice agent (no phone calls)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX
